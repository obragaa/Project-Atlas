# Atlas — environment template.
# Copy to `.env` and fill values. NEVER commit `.env` (see blueprint/16 - Security.md).
# All configuration is external to the build (blueprint/19 - DevOps.md, 20 - Infrastructure.md).

# ─── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── API (apps/api) ─────────────────────────────────────────────────────────
API_PORT=3333
API_HOST=0.0.0.0
# Comma-separated list of allowed origins (no wildcards in production — doc 16).
API_CORS_ORIGINS=http://localhost:3000

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://atlas:atlas@localhost:5432/atlas?schema=public

# ─── Cache / sessions / rate limiting (Redis) ───────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication (blueprint/15 - Authentication.md) ──────────────────────
# Secrets for signing tokens. Generate strong random values per environment.
AUTH_ACCESS_TOKEN_SECRET=change-me-access-secret
AUTH_REFRESH_TOKEN_SECRET=change-me-refresh-secret
AUTH_ACCESS_TOKEN_TTL=900
AUTH_REFRESH_TOKEN_TTL=2592000

# ─── Atlas AI (blueprint/22 - AI Engineering.md) ────────────────────────────
# Provider is selected behind a provider-agnostic gateway (ADR-0002).
AI_PROVIDER=anthropic
AI_ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=claude-opus-4-8
AI_CHAT_LATENCY_BUDGET_MS=3000

# ─── Observability (blueprint/21 - Observability.md) ────────────────────────
OTEL_SERVICE_NAME=atlas-api
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info

# ─── Web (apps/web) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:3333
